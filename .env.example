# Binance (use testnet first)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=True

# Execution
PAPER_TRADING=True

# Single pair (used if TRADING_PAIRS is not set)
TRADING_PAIR=ETHUSDT
# Multi-asset: comma-separated (e.g. ETHUSDT,BTCUSDT,SOLUSDT)
# TRADING_PAIRS=ETHUSDT,BTCUSDT,SOLUSDT

TIMEFRAME=4h

# Risk
INITIAL_CAPITAL=1000
DAILY_LOSS_LIMIT_PERCENT=3.0
STOP_LOSS_ATR_MULTIPLIER=2.0
TRADING_START_HOUR=8
TRADING_END_HOUR=17
MAX_CONSECUTIVE_API_ERRORS=5
MAX_PRICE_MOVE_PERCENT=10.0

# Optional: backtest
# BACKTEST_LOOKBACK_YEARS=8
# TRADING_FEE_PERCENT=0.1
# SLIPPAGE_PERCENT=0.05

# Optional: Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
